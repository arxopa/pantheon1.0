# ---------------------------------------------------------------------------\par
# RTF helpers\par
# ---------------------------------------------------------------------------\par
\par
def _rtf_escape(text):\par
    """Escape special RTF characters and encode non-ASCII as Unicode escapes."""\par
    out = []\par
    for ch in text:\par
        if ch == "\\\\":\par
            out.append("\\\\\\\\")\par
        elif ch == "\{":\par
            out.append("\\\\\{")\par
        elif ch == "\}":\par
            out.append("\\\\\}")\par
        elif ch == "\\n":\par
            out.append("\\\\par\\n")\par
        elif ch == "\\t":\par
            out.append("\\\\tab ")\par
        elif ord(ch) > 127:\par
            out.append(f"\\\\u\{ord(ch)\}?")\par
        else:\par
            out.append(ch)\par
    return "".join(out)\par
\par
\par
def _wrap_rtf(body_text, title=""):\par
    """Wrap plain text in a minimal RTF envelope."""\par
    header = (\par
        r"\{\\rtf1\\ansi\\deff0"\par
        r"\{\\fonttbl\{\\f0\\fmodern\\fcharset0 Courier New;\}\}"\par
        r"\{\\colortbl;\\red0\\green0\\blue0;\}"\par
        r"\\f0\\fs20 "\par
    )\par
    if title:\par
        header += r"\\b " + _rtf_escape(title) + r"\\b0\\par\\par "\par
    footer = "\}"\par
    return header + _rtf_escape(body_text) + footer\par
\par
\par
def write_rtf(path, body_text, title=""):\par
    """Write an RTF file at *path* with the given body text."""\par
    content = _wrap_rtf(body_text, title=title)\par
    with open(path, "w", encoding="utf-8") as fh:\par
        fh.write(content)\par
    print(f"  Written: \{path\}")\par
